              "fees": "None",
              "processing_time": "10 minutes",
              "person_responsible": "MSWDO Staff"
            }
          ]
        },
        {
          "step_number": 2,
          "client_action": "Submit all medical requirements stated in the checklist.",
          "agency_actions": [
            {
              "sub_step": "2.1",
              "action": "Receive requirements and check for completeness.",
              "fees": "None",
              "processing_time": "15 minutes",
              "person_responsible": "MSWDO Staff"
            }
          ]
        },
        {
